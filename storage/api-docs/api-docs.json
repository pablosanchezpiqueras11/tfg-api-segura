                                    "diagnostico": {
                                        "type": "string",
                                        "example": "Nuevo diagnóstico"
                                    },
                                    "paciente_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "medico_id": {
                                        "type": "integer",
                                        "example": 2
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Informe actualizado"
                    },
                    "403": {
                        "description": "Acceso no autorizado"
                    },
                    "404": {
                        "description": "Informe no encontrado"
