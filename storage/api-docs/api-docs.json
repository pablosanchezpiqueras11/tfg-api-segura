                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "temporary_token",
                                    "code"
                                ],
                                "properties": {
                                    "temporary_token": {
                                        "type": "string",
                                        "example": "abc123..."
                                    },
                                    "code": {
                                        "type": "string",
                                        "example": "123456"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
